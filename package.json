{
  "name": "calendar",
  "private": true,
  "type": "module",
  "scripts": {
    "worker:build-static": "poetry run python cloudflare/scripts/build_static_calendar.py",
    "worker:check": "node --check cloudflare/src/index.js",
    "worker:bundle-check": "npm run worker:build-static && npx wrangler deploy --dry-run",
    "worker:parity": "node cloudflare/scripts/check-parity.mjs",
    "worker:smoke": "npm run worker:build-static && node cloudflare/scripts/smoke-fetch.mjs",
    "worker:verify": "npm run worker:check && npm run worker:parity && npm run worker:smoke && npm run worker:bundle-check",
    "cf:deploy": "wrangler deploy",
    "cf:dev": "wrangler dev"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "wrangler": "^4.77.0"
  }
}
